    "test": "pnpm -r test",
    "deps-guard": "node scripts/deps-guard.mjs"
  },
  "devDependencies": {
    "concurrently": "9.2.3",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=24.17.0"
  },
  "packageManager": "pnpm@10.17.1"
}