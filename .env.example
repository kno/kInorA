# Local PostgreSQL defaults used by docker-compose.yml.
POSTGRES_DB=kinora
POSTGRES_USER=kinora
POSTGRES_PASSWORD=kinora
DATABASE_URL=postgres://kinora:kinora@localhost:5432/kinora

# Application ports.
API_PORT=4000
WEB_PORT=3000

# Compose/project metadata.
COMPOSE_PROJECT_NAME=kinora

# GHCR image settings used by CI/CD and VPS deployment.
GHCR_IMAGE=ghcr.io/<owner>/<repo>
IMAGE_TAG=latest

# Production deployment assumptions:
# - Configure GitHub secrets: VPS_HOST, VPS_USER, VPS_SSH_KEY, VPS_KNOWN_HOSTS,
#   optional VPS_PORT, optional VPS_DEPLOY_DIR, and PRODUCTION_BASE_URL.
# - VPS_KNOWN_HOSTS must contain the base64-encoded (or literal) ssh-keyscan output
#   for the VPS host (pinned host key fingerprint). The deploy workflow uses this
#   instead of ssh-keyscan to avoid trust-on-first-use.
# - The VPS deployment directory contains this repository plus a production .env.
# - The VPS has Docker, Docker Compose, Node.js 24+, and pnpm 10.17.1 available.
# - PostgreSQL data stays in the Docker Compose volume named postgres-data.
