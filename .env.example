# Local PostgreSQL defaults used by docker-compose.yml.
POSTGRES_DB=kinora
POSTGRES_USER=kinora
POSTGRES_PASSWORD=kinora
DATABASE_URL=postgres://kinora:kinora@localhost:5432/kinora

# Compose/project metadata.
COMPOSE_PROJECT_NAME=kinora

# GHCR image settings used by CI/CD and VPS deployment.
GHCR_IMAGE=ghcr.io/<owner>/<repo>
IMAGE_TAG=latest

# Public origin of the web app (scheme + host, no trailing slash).
# The Google OAuth redirect URI is derived from this as <WEB_PUBLIC_ORIGIN>/callback/social.
# That derived URI must match what is registered in the Google Cloud Console.
# Set WEB_PUBLIC_ORIGIN to your real public domain in production.
WEB_PUBLIC_ORIGIN=https://kinora.aitsai.com

# Google OAuth (server-side OIDC client used by the API).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OPTIONAL: explicit Google redirect URI override.
# Leave unset — the redirect URI is derived automatically as <WEB_PUBLIC_ORIGIN>/callback/social.
# Set only if the Google Console path differs from /callback/social.
# GOOGLE_REDIRECT_URI=https://kinora.aitsai.com/callback/social

# Web → API base URL used by the social-login proxy (server-side fetch).
# The api service publishes no ports; the web container reaches it over the
# Docker Compose network, so use the internal service hostname and port.
API_BASE_URL=http://api:4000

# AI plan generation — OpenRouter + Langfuse (08-v1-ai-plan-generation).
# These vars are required in production but NOT needed for local unit tests —
# the test suite uses MockPlanGenerator and does not call OpenRouter or Langfuse.

# OpenRouter API key — required for AI plan generation in production.
# Obtain at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter model identifier (OpenRouter provider/model namespace).
# MUST be a model that supports JSON-schema structured output (e.g. openai/gpt-4o-mini).
# See apps/api/README.md for the full list of requirements.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Additional AI provider API keys (09-ai-provider-admin).
# Only the key for the currently-selected provider needs to be set.
# These are operator-managed via the server .env — NOT stored in the DB or shown in the UI.

# OpenAI — required only when provider "openai" is selected via the admin panel.
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — required only when provider "anthropic" is selected via the admin panel.
# Obtain at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Generative AI — required only when provider "google" is selected.
# Obtain at: https://ai.google.dev/gemini-api/docs/api-key
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenCode-Go — required only when provider "opencode-go" is selected.
# Obtain at: https://opencode.ai
OPENCODE_GO_API_KEY=

# Langfuse observability — traces LLM calls (NO-OP when keys are unset).
# Obtain at: https://cloud.langfuse.com (or your self-hosted instance).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Langfuse host. Use https://cloud.langfuse.com for Langfuse Cloud.
LANGFUSE_HOST=https://cloud.langfuse.com

# Production deployment assumptions:
# - Configure GitHub secrets: VPS_HOST, VPS_USER, VPS_SSH_KEY, VPS_KNOWN_HOSTS,
#   optional VPS_PORT, optional VPS_DEPLOY_DIR, and PRODUCTION_BASE_URL.
# - VPS_KNOWN_HOSTS must contain the base64-encoded (or literal) ssh-keyscan output
#   for the VPS host (pinned host key fingerprint). The deploy workflow uses this
#   instead of ssh-keyscan to avoid trust-on-first-use.
# - The VPS deployment directory contains this repository plus a production .env.
# - The VPS has Docker, Docker Compose, Node.js 24+, and pnpm 10.17.1 available.
# - PostgreSQL data stays in the Docker Compose volume named postgres-data.
