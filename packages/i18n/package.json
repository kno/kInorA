{
  "name": "@kinora/i18n",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./messages/en": {
      "source": "./src/messages/en.json",
      "default": "./dist/messages/en.json"
    },
    "./messages/es": {
      "source": "./src/messages/es.json",
      "default": "./dist/messages/es.json"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
