{
  "name": "@kinora/domain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./plan": {
      "source": "./src/plan/index.ts",
      "types": "./src/plan/index.ts",
      "default": "./dist/plan/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kinora/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
