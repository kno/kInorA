<?xml version="1.0" encoding="utf-8"?>
<!--
  Data Extraction Rules (API 31+)
  Controls what is included in both cloud backups and device-to-device
  transfers.  Excludes all session-sensitive storage.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude shared preferences (may contain tokens / session state) -->
        <exclude domain="sharedpref" path="." />
        <!-- Exclude all databases -->
        <exclude domain="database" path="." />
        <!-- Exclude Capacitor/WebView storage -->
        <exclude domain="root" path="app_webview" />
        <!-- Exclude external storage used by FileProvider -->
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Same exclusions apply to device-to-device transfer (D2D) -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="root" path="app_webview" />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
